# DPI WorkOps API — environment variables
# Copy to .env and fill in values

APP_NAME="DPI WorkOps API"
DEBUG=false
DB_PATH=./data/workops.db
CONFIG_DIR=../../config

# CORS — add your Pages preview URLs as needed
CORS_ORIGINS='["http://localhost:5173","https://dpi-workops.pages.dev"]'

# Operating law — both must remain false until approval gate is fully wired
ALLOW_AUTONOMOUS_SEND=false
ALLOW_AUTONOMOUS_SUBMIT=false
